# ECHO VTT — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── AI Provider ───────────────────────────────────────────────────────
# Options: anthropic | openai | openai_compatible | ollama | ollama_cloud | mock
# Use "mock" to run without any API key (great for development).
AI_PROVIDER=mock
AI_MODEL=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI or any OpenAI-compatible API (Groq, Together, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama local (no API key needed — runs on your machine)
# Make sure Ollama is running: https://ollama.com
# Pull a model first: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Ollama Cloud (hosted inference — requires API key from ollama.com)
# Sign up at ollama.com and generate an API key.
# Uses the native Ollama API (NOT the OpenAI-compatible /v1 endpoint).
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/api
OLLAMA_CLOUD_MODEL=llama3.3:70b

# ── Image Generation ──────────────────────────────────────────────────
# Options: openai_dalle | stability | mock
IMAGE_PROVIDER=mock
STABILITY_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-random-256bit-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Payments (optional) ───────────────────────────────────────────────
# Leave blank to disable payments (everyone can create chronicles free).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYMENTS_ENABLED=false
